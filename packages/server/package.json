{
  "name": "server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Hono HTTP server exposing read-only routes against choda-deck artifacts dir + SQLite.",
  "scripts": {
    "start": "tsx src/server.ts",
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "docker:build": "docker build -t choda-companion-server .",
    "docker:run": "docker run --rm -v $CHODA_DATA_HOST:/data:ro -e CHODA_DB_PATH=/data/database/choda-deck.db -e CHODA_ARTIFACTS_DIR=/data/artifacts -p 8080:8080 choda-companion-server --bind 0.0.0.0"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.8",
    "better-sqlite3": "^11.10.0",
    "hono": "^4.7.10"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.0",
    "vitest": "^2.1.8"
  }
}
