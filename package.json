{
  "name": "choda-deck-companion",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Companion web client for managing the choda-deck knowledgebase. Talks to ONE API: the laptop REST adapter (single source of truth).",
  "packageManager": "pnpm@11.0.9",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "pnpm --filter web dev",
    "build": "pnpm --filter web build",
    "test": "pnpm -r --filter=./packages/* run test",
    "typecheck": "pnpm -r --filter=./packages/* run typecheck",
    "lint": "eslint ."
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@types/node": "^22.10.0",
    "eslint": "^9.18.0",
    "globals": "^15.14.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.20.0"
  }
}
