{
  "name": "choda-deck-companion",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Thin clients on top of choda-deck filesystem artifacts (queue.jsonl per ADR-019). Phase 1: ntfy notifier.",
  "packageManager": "pnpm@11.0.9",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "lint": "eslint .",
    "test": "pnpm -r --filter=./packages/* run test",
    "typecheck": "pnpm -r --filter=./packages/* run typecheck",
    "dev:server": "pnpm --filter server dev",
    "dev:web": "pnpm --filter web dev",
    "build:shared": "pnpm --filter shared build",
    "build:web": "pnpm --filter web build",
    "build:server": "pnpm --filter server build",
    "build": "pnpm build:shared && pnpm build:web && pnpm build:server"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@types/node": "^22.10.0",
    "eslint": "^9.18.0",
    "globals": "^15.14.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.20.0"
  }
}
